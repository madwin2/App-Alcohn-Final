# Puerto HTTP
PORT=8787

# Protección del worker (mandar en Authorization: Bearer ...)
WORKER_API_KEY=cambiar-por-un-secreto-largo

# Credenciales MiCorreo (portal web, no API REST)
MICORREO_USER=tu@email.com
MICORREO_PASSWORD=tu-contraseña

# URLs del portal
MICORREO_LOGIN_URL=https://www.correoargentino.com.ar/MiCorreo/public/
# MICORREO_UPLOAD_URL=https://www.correoargentino.com.ar/MiCorreo/...

# Playwright
MICORREO_HEADLESS=true
MICORREO_TIMEOUT_MS=60000
MICORREO_SLOW_MO_MS=0

# Reintentos de login (MiCorreo falla a veces si ya hay sesión abierta)
MICORREO_LOGIN_MAX_RETRIES=3

# Origen en envíos masivos (wizard antes del CSV)
MICORREO_ORIGEN_PROVINCIA=B
MICORREO_ORIGEN_SUCURSAL=MAR DEL PLATA UP 28

# Selectores (el login usa #formLogin por código; estos son fallback/documentación)
MICORREO_SELECTOR_USER=#formLogin input[name="email"], #formLogin #email
MICORREO_SELECTOR_PASSWORD=#formLogin input[name="password"], #formLogin #password
MICORREO_SELECTOR_LOGIN_BUTTON=#formLogin button[type="submit"]
MICORREO_SELECTOR_FILE_INPUT=input[type="file"]
MICORREO_SELECTOR_SUBMIT_UPLOAD=button:has-text("Cargar"), button:has-text("Subir"), button:has-text("Importar")

MICORREO_NAV_LINKS=Envío masivo,Masivo,Nuevo Envío,Envío de paquete
MICORREO_ARTIFACTS_DIR=./artifacts
