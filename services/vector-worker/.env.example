PORT=8790
VECTOR_WORKER_API_KEY=generar-secreto-largo
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
VECTOR_BUCKET=vector

# Loop worker
VECTOR_POLL_INTERVAL_SECONDS=12
VECTOR_LOCK_STALE_MINUTES=15
VECTOR_MAX_ATTEMPTS_DEFAULT=4

# Pipeline: Upscayl (IA) -> mkbitmap -> Potrace
POTRACE_BIN=potrace
MKBITMAP_BIN=mkbitmap
UPSCAYL_BIN=/opt/upscayl-ncnn/upscayl-bin-20251207-174704-linux/upscayl-bin
VECTOR_ENGINE=potrace

# Upscale con Real-ESRGAN (backend de Upscayl)
VECTOR_UPSCALE_ENABLED=true
VECTOR_UPSCALE_FACTOR=4
VECTOR_UPSCALE_MODEL=realesrgan-x4plus
VECTOR_UPSCALE_MODEL_LOW_QUALITY=realesrgan-x4plus
VECTOR_UPSCALE_TILE_SIZE=256

# Mejora previa con OpenAI (mismo prompt que /api/optimize-logo)
OPENAI_API_KEY=tu-openai-api-key
VECTOR_AI_ENHANCE_ENABLED=true
VECTOR_AI_ENHANCE_MODEL=gpt-image-1

# Bitmap final antes de Potrace (pipeline classic sin IA)
VECTOR_TARGET_LONG_SIDE=2800
VECTOR_AI_TARGET_LONG_SIDE=3600
VECTOR_MAX_UPSCALE=4
VECTOR_MAX_MEGAPIXELS=8
