# Worker MiCorreo (Hetzner) — proxy desde la app
# En Vercel: Project Settings → Environment Variables
MICORREO_WORKER_URL=https://webhook.alcohncnc.com/micorreo
MICORREO_WORKER_API_KEY=el-mismo-valor-que-WORKER_API_KEY-en-hetzner
VECTOR_WORKER_URL=https://webhook.alcohncnc.com/vector
VECTOR_WORKER_API_KEY=el-mismo-valor-que-VECTOR_WORKER_API_KEY-en-hetzner

# Vectorización automática al subir archivo base (false = desactivado)
VITE_VECTOR_AUTO_ENABLED=false
VECTOR_AUTO_ENABLED=false
